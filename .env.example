# ============================================
# ConfidentialRAG Environment Configuration
# ============================================
#
# IMPORTANT: Never commit this file with real values!
# Copy this file to .env and replace all CHANGE_* values.
#
# Generate secure values:
#   openssl rand -base64 32  (for passwords)
#   openssl rand -hex 32     (for tokens/keys)
#

# PostgreSQL Configuration
# ----------------------------------------
# Database credentials for document registry
POSTGRES_USER=raguser
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD  # Generate: openssl rand -base64 32
POSTGRES_DB=confidentialrag

# ChromaDB Configuration
# ----------------------------------------
# Vector database authentication token
CHROMA_AUTH_TOKEN=CHANGE_THIS_TOKEN  # Generate: openssl rand -hex 32

# Application Secret Key
# ----------------------------------------
# Used for JWT tokens and cryptographic operations
SECRET_KEY=CHANGE_THIS_SECRET_KEY  # Generate: openssl rand -hex 32

# Backend Configuration
# ----------------------------------------
# Database connection URLs (use variables above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
CHROMA_URL=http://localhost:8000
OLLAMA_URL=http://localhost:11434

# Midnight Blockchain Configuration
# ----------------------------------------
# Local development network endpoints (Docker services)
MIDNIGHT_NODE_URL=http://localhost:8080
MIDNIGHT_INDEXER_URL=http://localhost:8081
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300

# Contract address (populated after deployment)
MIDNIGHT_CONTRACT_ADDRESS=

# Private key for signing transactions (KEEP SECRET!)
# Generate: Use Midnight CLI wallet creation
MIDNIGHT_PRIVATE_KEY=

# Environment Settings
# ----------------------------------------
# Set to 'true' for development, 'false' for production
DEBUG=false
